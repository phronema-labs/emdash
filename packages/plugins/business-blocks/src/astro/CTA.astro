---
interface Props {
	node: {
		headline: string;
		description?: string;
		buttonLabel: string;
		buttonUrl: string;
		style?: "banner" | "card" | "inline";
	};
}

const { node } = Astro.props;
const { headline, description, buttonLabel, buttonUrl, style = "banner" } = node;
---

<section class:list={["cta", `cta-${style}`, "section"]}>
	<div class="container">
		<div class="cta-content">
			<h2 class="cta-headline">{headline}</h2>
			{description && <p class="cta-description">{description}</p>}
			<a href={buttonUrl} class="btn btn-primary btn-lg">{buttonLabel}</a>
		</div>
	</div>
</section>

<style>
	.cta-banner {
		background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
		color: white;
	}

	.cta-banner .cta-description {
		color: rgba(255, 255, 255, 0.85);
	}

	.cta-banner .btn {
		background: white;
		color: var(--color-primary);
	}

	.cta-banner .btn:hover {
		background: var(--color-surface);
	}

	.cta-card {
		background: var(--color-surface);
	}

	.cta-card .cta-content {
		background: var(--color-bg);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		padding: var(--spacing-3xl);
	}

	.cta-content {
		text-align: center;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: var(--spacing-md);
	}

	.cta-headline {
		font-size: var(--font-size-3xl);
		font-weight: 800;
	}

	.cta-description {
		font-size: var(--font-size-lg);
		color: var(--color-muted);
		max-width: 600px;
	}
</style>
