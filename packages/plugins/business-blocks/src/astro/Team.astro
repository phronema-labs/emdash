---
interface Props {
	node: {
		headline?: string;
		members: Array<{
			name: string;
			role?: string;
			photo?: string;
			bio?: string;
			social?: Record<string, string>;
		}>;
	};
}

const { node } = Astro.props;
const { headline, members } = node;

const SOCIAL_ICONS: Record<string, string> = {
	linkedin: "ph-linkedin-logo",
	twitter: "ph-x-logo",
	github: "ph-github-logo",
	instagram: "ph-instagram-logo",
	facebook: "ph-facebook-logo",
	dribbble: "ph-dribbble-logo",
	website: "ph-globe",
};
---

<section class="team section">
	<div class="container">
		{headline && (
			<header class="team-header">
				<h2 class="team-headline">{headline}</h2>
			</header>
		)}
		<div class="team-grid">
			{members.map((member) => (
				<div class="team-card">
					{member.photo && (
						<img src={member.photo} alt={member.name} class="team-photo" loading="lazy" />
					)}
					<h3 class="team-name">{member.name}</h3>
					{member.role && <p class="team-role">{member.role}</p>}
					{member.bio && <p class="team-bio">{member.bio}</p>}
					{member.social && Object.keys(member.social).length > 0 && (
						<div class="team-social">
							{Object.entries(member.social).map(([platform, url]) => (
								<a href={url} target="_blank" rel="noopener noreferrer" aria-label={platform}>
									<i class={`ph ${SOCIAL_ICONS[platform] || "ph-link"}`} />
								</a>
							))}
						</div>
					)}
				</div>
			))}
		</div>
	</div>
</section>

<style>
	.team-header {
		text-align: center;
		margin-bottom: var(--spacing-4xl);
	}

	.team-headline {
		font-size: var(--font-size-3xl);
		font-weight: 800;
	}

	.team-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: var(--spacing-xl);
	}

	.team-card {
		text-align: center;
		padding: var(--spacing-xl);
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
	}

	.team-photo {
		width: 120px;
		height: 120px;
		border-radius: var(--radius-full);
		object-fit: cover;
		margin-bottom: var(--spacing-md);
	}

	.team-name {
		font-size: var(--font-size-lg);
		font-weight: 700;
	}

	.team-role {
		color: var(--color-primary);
		font-size: var(--font-size-sm);
		font-weight: 500;
		margin-top: var(--spacing-xs);
	}

	.team-bio {
		color: var(--color-muted);
		font-size: var(--font-size-sm);
		line-height: 1.6;
		margin-top: var(--spacing-md);
	}

	.team-social {
		display: flex;
		justify-content: center;
		gap: var(--spacing-sm);
		margin-top: var(--spacing-md);
	}

	.team-social a {
		width: 36px;
		height: 36px;
		border-radius: var(--radius-full);
		background: var(--color-bg);
		display: flex;
		align-items: center;
		justify-content: center;
		color: var(--color-muted);
		transition: all var(--transition-fast);
		font-size: 18px;
	}

	.team-social a:hover {
		color: var(--color-primary);
		background: var(--color-primary-light);
	}

	@media (max-width: 900px) {
		.team-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 600px) {
		.team-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
