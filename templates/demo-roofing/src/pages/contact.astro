---
import Base from "../layouts/Base.astro";

let formSuccess = false;
let formError = "";

if (Astro.request.method === "POST") {
	const formData = await Astro.request.formData();
	const name = formData.get("name")?.toString().trim();
	const email = formData.get("email")?.toString().trim();
	const message = formData.get("message")?.toString().trim();

	if (!name || !email || !message) {
		formError = "Please fill in all required fields.";
	} else if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
		formError = "Please enter a valid email address.";
	} else {
		formSuccess = true;
	}
}
---

<Base title="Contact Us" description="Get in touch for a free consultation about your home service needs.">
	{/* Hero */}
	<section class="section" style="padding-bottom: var(--spacing-xl);">
		<div class="container" style="text-align: center;">
			<h1>Get in touch</h1>
			<p style="color: var(--color-muted); font-size: var(--font-size-lg); margin-top: var(--spacing-sm); max-width: 600px; margin-inline: auto;">
				Request a quote, schedule service, or ask a question. We respond within 1 business hour during working hours.
			</p>
		</div>
	</section>

	{/* Two-column: Info left, Form right */}
	<section class="container contact-section">
		<div class="contact-two-col">
			{/* LEFT: Contact info + hours */}
			<div class="contact-left">
				<div class="info-block">
					<div class="info-item">
						<div class="info-icon"><i class="ph ph-phone" /></div>
						<div>
							<h3>Call Us</h3>
							<a href="tel:5552345678">(555) 234-5678</a>
							<span>24/7 for emergencies</span>
						</div>
					</div>
					<div class="info-item">
						<div class="info-icon"><i class="ph ph-envelope" /></div>
						<div>
							<h3>Email</h3>
							<a href="mailto:service@summithomeservices.com">service@summithomeservices.com</a>
							<span>We respond within 1 hour</span>
						</div>
					</div>
					<div class="info-item">
						<div class="info-icon"><i class="ph ph-map-pin" /></div>
						<div>
							<h3>Location</h3>
							<p>482 Industrial Parkway, Suite 5</p>
							<span>Springfield, ST 62704</span>
						</div>
					</div>
				</div>

				<div class="hours-block">
					<h3><i class="ph ph-clock" /> Business Hours</h3>
					<table class="hours-table">
						<tbody>
							<tr><td>Monday – Friday</td><td>7:00 AM – 6:00 PM</td></tr>
							<tr><td>Saturday</td><td>8:00 AM – 2:00 PM</td></tr>
							<tr><td>Sunday</td><td class="closed">Closed</td></tr>
							<tr class="emergency-row"><td>Emergency</td><td>24/7</td></tr>
						</tbody>
					</table>
				</div>

				<div class="social-row">
					<a href="https://facebook.com/summithomeservices" target="_blank" rel="noopener noreferrer" aria-label="Facebook"><i class="ph ph-facebook-logo" /></a>
					<a href="https://instagram.com/summithomeservices" target="_blank" rel="noopener noreferrer" aria-label="Instagram"><i class="ph ph-instagram-logo" /></a>
					<a href="https://g.page/summithomeservices" target="_blank" rel="noopener noreferrer" aria-label="Google"><i class="ph ph-google-logo" /></a>
				</div>
			</div>

			{/* RIGHT: Contact form */}
			<div class="contact-right">
				<div class="form-card">
					<h2>Send us a message</h2>

					{formSuccess ? (
						<div class="form-success">
							<i class="ph ph-check-circle" />
							<h3>Thank you!</h3>
							<p>We've received your message and will get back to you within one business hour.</p>
						</div>
					) : (
						<form method="POST" class="contact-form">
							{formError && <p class="form-error">{formError}</p>}
							<div class="form-row">
								<div class="form-group">
									<label for="name">Name *</label>
									<input type="text" id="name" name="name" required placeholder="Your name" />
								</div>
								<div class="form-group">
									<label for="email">Email *</label>
									<input type="email" id="email" name="email" required placeholder="you@example.com" />
								</div>
							</div>
							<div class="form-row">
								<div class="form-group">
									<label for="phone">Phone</label>
									<input type="tel" id="phone" name="phone" placeholder="(555) 000-0000" />
								</div>
								<div class="form-group">
									<label for="service">Service Needed</label>
									<select id="service" name="service">
										<option value="">Select a service...</option>
										<option value="plumbing">Plumbing</option>
										<option value="hvac">Heating & AC</option>
										<option value="electrical">Electrical</option>
										<option value="emergency">Emergency Service</option>
										<option value="other">Other</option>
									</select>
								</div>
							</div>
							<div class="form-group">
								<label for="message">How can we help? *</label>
								<textarea id="message" name="message" rows="5" required placeholder="Describe what you need..."></textarea>
							</div>
							<button type="submit" class="btn btn-primary btn-lg" style="width: 100%;">Send Message</button>
						</form>
					)}
				</div>
			</div>
		</div>
	</section>

	{/* Full-width map pinned to Springfield */}
	<section class="map-full">
		<iframe
			src="https://www.openstreetmap.org/export/embed.html?bbox=-89.67%2C39.77%2C-89.63%2C39.80&layer=mapnik&marker=39.7817%2C-89.6501"
			width="100%"
			height="400"
			style="border: 0; display: block;"
			loading="lazy"
			title="Summit Home Services — 482 Industrial Parkway, Springfield"
		></iframe>
		<div class="map-overlay">
			<div class="container">
				<div class="map-badge">
					<i class="ph ph-map-pin" />
					<div>
						<strong>Summit Home Services</strong>
						<span>482 Industrial Parkway, Suite 5, Springfield, ST 62704</span>
					</div>
				</div>
			</div>
		</div>
	</section>
</Base>

<style>
	.contact-section {
		padding-bottom: var(--spacing-4xl);
	}

	.contact-two-col {
		display: grid;
		grid-template-columns: 1fr 1.3fr;
		gap: var(--spacing-3xl);
		align-items: start;
	}

	/* Left column */
	.contact-left {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-xl);
	}

	.info-block {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-lg);
	}

	.info-item {
		display: flex;
		gap: var(--spacing-md);
	}

	.info-icon {
		width: 44px;
		height: 44px;
		border-radius: var(--radius);
		background: var(--color-primary);
		color: white;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 20px;
		flex-shrink: 0;
	}

	.info-item h3 {
		font-size: var(--font-size-sm);
		font-weight: 700;
		margin-bottom: 2px;
	}

	.info-item a {
		font-size: var(--font-size-sm);
		color: var(--color-text);
		text-decoration: none;
		display: block;
	}

	.info-item a:hover {
		color: var(--color-primary);
	}

	.info-item p {
		font-size: var(--font-size-sm);
	}

	.info-item span {
		font-size: var(--font-size-xs);
		color: var(--color-muted);
	}

	/* Hours */
	.hours-block {
		padding: var(--spacing-lg);
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
	}

	.hours-block h3 {
		font-size: var(--font-size-sm);
		font-weight: 700;
		display: flex;
		align-items: center;
		gap: var(--spacing-xs);
		margin-bottom: var(--spacing-md);
	}

	.hours-block h3 i {
		color: var(--color-primary);
	}

	.hours-table {
		width: 100%;
		border-collapse: collapse;
	}

	.hours-table td {
		padding: var(--spacing-xs) 0;
		font-size: var(--font-size-sm);
		border-bottom: 1px solid var(--color-border);
	}

	.hours-table td:last-child {
		text-align: right;
		color: var(--color-muted);
	}

	.hours-table tr:last-child td {
		border-bottom: none;
	}

	.hours-table .closed {
		font-style: italic;
	}

	.emergency-row td {
		padding-top: var(--spacing-sm) !important;
		font-weight: 700;
		color: var(--color-primary) !important;
	}

	/* Social */
	.social-row {
		display: flex;
		gap: var(--spacing-sm);
	}

	.social-row a {
		width: 44px;
		height: 44px;
		display: flex;
		align-items: center;
		justify-content: center;
		border: 1px solid var(--color-border);
		border-radius: var(--radius);
		font-size: 22px;
		color: var(--color-muted);
		transition: all var(--transition-fast);
	}

	.social-row a:hover {
		background: var(--color-primary);
		color: white;
		border-color: var(--color-primary);
	}

	/* Right column — form */
	.form-card {
		padding: var(--spacing-2xl);
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
	}

	.form-card h2 {
		font-size: var(--font-size-xl);
		margin-bottom: var(--spacing-xl);
	}

	.contact-form {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-md);
	}

	.form-row {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: var(--spacing-md);
	}

	.form-group {
		display: flex;
		flex-direction: column;
		gap: 4px;
	}

	.form-group label {
		font-weight: 500;
		font-size: var(--font-size-sm);
	}

	.form-group input,
	.form-group textarea,
	.form-group select {
		padding: 10px 14px;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-sm);
		font-family: inherit;
		font-size: var(--font-size-base);
		background: var(--color-bg);
		color: var(--color-text);
		transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
	}

	.form-group input:focus,
	.form-group textarea:focus,
	.form-group select:focus {
		outline: none;
		border-color: var(--color-primary);
		box-shadow: 0 0 0 3px rgba(255, 107, 53, 0.1);
	}

	.form-group input::placeholder,
	.form-group textarea::placeholder {
		color: var(--color-muted);
		opacity: 0.5;
	}

	.form-error {
		padding: var(--spacing-md);
		background: #fef2f2;
		color: #dc2626;
		border-radius: var(--radius-sm);
		font-size: var(--font-size-sm);
	}

	.form-success {
		text-align: center;
		padding: var(--spacing-2xl);
	}

	.form-success i { font-size: 48px; color: #22c55e; }
	.form-success h3 { margin-top: var(--spacing-md); }
	.form-success p { margin-top: var(--spacing-sm); color: var(--color-muted); }

	/* Map */
	.map-full {
		position: relative;
	}

	.map-overlay {
		position: absolute;
		bottom: var(--spacing-lg);
		left: 0;
		right: 0;
		pointer-events: none;
	}

	.map-badge {
		display: inline-flex;
		align-items: center;
		gap: var(--spacing-sm);
		background: var(--color-bg);
		padding: var(--spacing-md) var(--spacing-lg);
		border-radius: var(--radius);
		box-shadow: var(--shadow-lg);
		pointer-events: auto;
		margin-left: var(--spacing-xl);
	}

	.map-badge i {
		font-size: 24px;
		color: var(--color-primary);
	}

	.map-badge strong {
		display: block;
		font-size: var(--font-size-sm);
	}

	.map-badge span {
		display: block;
		font-size: var(--font-size-xs);
		color: var(--color-muted);
	}

	@media (max-width: 768px) {
		.contact-two-col {
			grid-template-columns: 1fr;
		}

		.form-row {
			grid-template-columns: 1fr;
		}

		.contact-left {
			order: 2;
		}

		.contact-right {
			order: 1;
		}
	}
</style>
