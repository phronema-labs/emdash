---
interface Props {
	title: string;
	summary?: string;
	icon?: string;
	priceFrom?: string;
	href: string;
	ctaLabel?: string;
}

const { title, summary, icon, priceFrom, href, ctaLabel } = Astro.props;

const ICON_MAP: Record<string, string> = {
	code: "ph-code",
	"paint-brush": "ph-paint-brush",
	"chart-line-up": "ph-chart-line-up",
	globe: "ph-globe",
	devices: "ph-devices",
	"shield-check": "ph-shield-check",
};
---

<a href={href} class="service-card">
	{icon && (
		<div class="service-icon">
			<i class={`ph ${ICON_MAP[icon] || `ph-${icon}`}`} />
		</div>
	)}
	<h3 class="service-title">{title}</h3>
	{summary && <p class="service-summary">{summary}</p>}
	{priceFrom && <p class="service-price">From {priceFrom}</p>}
	<span class="service-link">{ctaLabel || "Learn More"} &rarr;</span>
</a>

<style>
	.service-card {
		display: flex;
		flex-direction: column;
		padding: var(--spacing-xl);
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		transition: transform var(--transition-base), box-shadow var(--transition-base);
		text-decoration: none;
		color: var(--color-text);
	}

	.service-card:hover {
		transform: translateY(-4px);
		box-shadow: var(--shadow-lg);
	}

	.service-icon {
		width: 56px;
		height: 56px;
		border-radius: var(--radius);
		background: var(--color-primary-light);
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 28px;
		color: var(--color-primary-dark);
		margin-bottom: var(--spacing-md);
	}

	.service-title {
		font-size: var(--font-size-xl);
		font-weight: 700;
		margin-bottom: var(--spacing-sm);
	}

	.service-summary {
		color: var(--color-muted);
		line-height: 1.6;
		flex: 1;
	}

	.service-price {
		color: var(--color-primary);
		font-weight: 600;
		margin-top: var(--spacing-md);
	}

	.service-link {
		margin-top: var(--spacing-md);
		color: var(--color-primary);
		font-weight: 600;
		font-size: var(--font-size-sm);
	}
</style>
