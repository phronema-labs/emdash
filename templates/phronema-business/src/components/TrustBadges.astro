---
interface Props {
	badges?: Array<{
		icon: string;
		label: string;
		sublabel?: string;
	}>;
}

const { badges = [
	{ icon: "ph-shield-check", label: "Licensed & Insured", sublabel: "$2M Coverage" },
	{ icon: "ph-star", label: "4.9 Google Rating", sublabel: "500+ Reviews" },
	{ icon: "ph-clock", label: "Same-Day Service", sublabel: "Call Before Noon" },
	{ icon: "ph-seal-check", label: "Satisfaction Guarantee", sublabel: "Or Your Money Back" },
	{ icon: "ph-certificate", label: "BBB Accredited", sublabel: "A+ Rating" },
] } = Astro.props;
---

<section class="trust-badges">
	<div class="container">
		<div class="badges-strip">
			{badges.map((badge) => (
				<div class="badge">
					<i class={`ph ${badge.icon}`} />
					<div class="badge-text">
						<strong>{badge.label}</strong>
						{badge.sublabel && <span>{badge.sublabel}</span>}
					</div>
				</div>
			))}
		</div>
	</div>
</section>

<style>
	.trust-badges {
		background: var(--color-surface);
		border-top: 1px solid var(--color-border);
		border-bottom: 1px solid var(--color-border);
		padding: var(--space-lg) var(--site-gutter);
	}

	.badges-strip {
		display: flex;
		justify-content: center;
		flex-wrap: wrap;
		gap: var(--spacing-xl);
	}

	.badge {
		display: flex;
		align-items: center;
		gap: var(--spacing-sm);
	}

	.badge i {
		font-size: 28px;
		color: var(--color-primary);
	}

	.badge-text {
		display: flex;
		flex-direction: column;
	}

	.badge-text strong {
		font-size: var(--font-size-sm);
		font-weight: 600;
	}

	.badge-text span {
		font-size: var(--font-size-xs);
		color: var(--color-muted);
	}

	@media (max-width: 768px) {
		.badges-strip {
			gap: var(--spacing-lg);
		}

		.badge-text span {
			display: none;
		}
	}
</style>
