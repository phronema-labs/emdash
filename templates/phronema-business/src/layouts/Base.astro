---
import { getMenu, getSiteSettings } from "emdash";
import { EmDashHead } from "emdash/ui";
import { createPublicPageContext } from "emdash/page";
import { Font } from "astro:assets";
import TopBar from "../components/TopBar.astro";
import "../styles/site.css";
import "../styles/theme.css";

interface Props {
	title?: string;
	description?: string;
	image?: string;
}

const { title, description, image } = Astro.props;
const settings = await getSiteSettings();
const siteTitle = settings?.title || "Acme Services";
const fullTitle = title ? `${title} — ${siteTitle}` : siteTitle;
const siteDescription = settings?.tagline || "Professional solutions for growing businesses";
const siteLogo = (settings?.logo as any)?.url ? settings.logo as { mediaId: string; alt?: string; url: string } : null;
const siteFavicon = (settings?.favicon as any)?.url ?? null;

const menu = await getMenu("primary");
const footerMenu = await getMenu("footer");

const pageCtx = createPublicPageContext({
	Astro,
	kind: "custom",
	pageType: "website",
	title: fullTitle,
	pageTitle: title ?? siteTitle,
	description: description || siteDescription,
	canonical: Astro.url.href,
	image,
	seo: { ogImage: image },
	siteName: siteTitle,
});
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{fullTitle}</title>
		{siteFavicon && <link rel="icon" href={siteFavicon} />}
		<EmDashHead page={pageCtx} />
		<Font cssVariable="--font-sans" preload />
		<link href="https://unpkg.com/@phosphor-icons/web@2.1.2/src/regular/style.css" rel="stylesheet" />
		<link href="https://unpkg.com/@phosphor-icons/web@2.1.2/src/fill/style.css" rel="stylesheet" />
		<!-- Light mode only -->
	</head>
	<body>
		<TopBar />
		<header class="site-header">
			<nav class="nav">
				<a href="/" class="site-logo">
					{siteLogo
						? <img src={siteLogo.url} alt={siteLogo.alt || siteTitle} class="site-logo-img" />
						: <img src="/logo.svg" alt={siteTitle} class="site-logo-img" />
					}
				</a>
				<button class="nav-toggle" aria-label="Toggle navigation" aria-expanded="false">
					<i class="ph ph-list"></i>
				</button>
				<div class="nav-links">
					{menu?.items.map((item) => (
						<a href={item.url} target={item.target}>{item.label}</a>
					))}
				</div>
				<div class="nav-actions">
					<a href="/contact" class="nav-cta">Get a Quote</a>
				</div>
			</nav>
		</header>

		<main>
			<slot />
		</main>

		<footer class="site-footer">
			<div class="footer-top">
				<div class="container footer-grid">
					{/* Brand column */}
					<div class="footer-brand">
						<span class="footer-logo">
							{siteLogo
								? <img src={siteLogo.url} alt={siteLogo.alt || siteTitle} class="footer-logo-img" />
								: <img src="/logo.svg" alt={siteTitle} class="footer-logo-img" />
							}
						</span>
						<p class="footer-tagline">{settings?.tagline || "Trusted plumbing, HVAC & electrical"}</p>
						<div class="footer-social">
							<a href="https://facebook.com" target="_blank" rel="noopener noreferrer" aria-label="Facebook"><i class="ph ph-facebook-logo" /></a>
							<a href="https://instagram.com" target="_blank" rel="noopener noreferrer" aria-label="Instagram"><i class="ph ph-instagram-logo" /></a>
							<a href="https://google.com" target="_blank" rel="noopener noreferrer" aria-label="Google"><i class="ph ph-google-logo" /></a>
						</div>
					</div>

					{/* Services column */}
					<div class="footer-col">
						<h4>Services</h4>
						<a href="/services/plumbing">Plumbing</a>
						<a href="/services/hvac">Heating & AC</a>
						<a href="/services/electrical">Electrical</a>
						<a href="/services/emergency-services">Emergency Service</a>
						<a href="/services">All Services</a>
					</div>

					{/* Company column */}
					<div class="footer-col">
						<h4>Company</h4>
						<a href="/about">About Us</a>
						<a href="/work">Our Work</a>
						<a href="/blog">Blog</a>
						<a href="/testimonials">Testimonials</a>
						<a href="/faq">FAQ</a>
					</div>

					{/* Contact column */}
					<div class="footer-col footer-contact">
						<h4>Contact Us</h4>
						<a href="tel:5552345678"><i class="ph ph-phone" /> (555) 234-5678</a>
						<a href="mailto:service@summithomeservices.com"><i class="ph ph-envelope" /> service@summithomeservices.com</a>
						<p><i class="ph ph-map-pin" /> 482 Industrial Pkwy, Suite 5<br />Springfield, ST 62704</p>
						<p class="footer-hours"><i class="ph ph-clock" /> Mon–Fri 7AM–6PM · Sat 8AM–2PM</p>
					</div>
				</div>
			</div>

			<div class="footer-bottom">
				<div class="container footer-bottom-inner">
					<p>&copy; {new Date().getFullYear()} {siteTitle}. All rights reserved.</p>
					<div class="footer-bottom-links">
						{footerMenu?.items.map((item) => (
							<a href={item.url}>{item.label}</a>
						))}
						<a href="/_emdash/admin" class="admin-link"><i class="ph ph-lock-simple" /> Client Login</a>
					</div>
					<p class="footer-powered">
						Built by <a href="https://phronemalabs.com" class="phronema-link">
							<svg width="14" height="14" viewBox="0 0 24 24" fill="none" style="display:inline-block;vertical-align:-2px;margin-right:2px;">
								<path d="M12 2L2 7l10 5 10-5-10-5z" fill="#FF6B35"/>
								<path d="M2 17l10 5 10-5" stroke="#FF6B35" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
								<path d="M2 12l10 5 10-5" stroke="#FF6B35" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
							</svg>Phronema Labs</a>
					</p>
				</div>
			</div>
		</footer>

		<script>
			// Mobile nav toggle
			const toggle = document.querySelector<HTMLButtonElement>(".nav-toggle");
			const links = document.querySelector<HTMLElement>(".nav-links");
			toggle?.addEventListener("click", () => {
				const expanded = toggle.getAttribute("aria-expanded") === "true";
				toggle.setAttribute("aria-expanded", String(!expanded));
				links?.classList.toggle("nav-open");
			});
		</script>

		<style is:global>
			@layer base;

			@layer base {
				*, *::before, *::after {
					box-sizing: border-box;
					margin: 0;
					padding: 0;
				}

				:root {
					--color-bg: #ffffff;
					--color-text: #1f1f1f;
					--color-muted: #64748b;
					--color-border: #e2e8f0;
					--color-surface: #f8fafc;
					--color-primary: #ff6b35;
					--color-primary-dark: #e55a2b;
					--color-primary-light: #ff8c61;
					--color-accent: #ff6b35;
					--color-accent-light: #ffb899;
					--color-success: #22c55e;
					--color-warning: #f59e0b;

					--font-mono: ui-monospace, "SF Mono", monospace;
					--font-size-xs: 0.8125rem;
					--font-size-sm: 0.9375rem;
					--font-size-base: 1.0625rem;
					--font-size-md: 1.0625rem;
					--font-size-lg: 1.1875rem;
					--font-size-xl: 1.375rem;
					--font-size-2xl: 1.75rem;
					--font-size-3xl: 2.5rem;
					--font-size-4xl: 3.25rem;
					--font-size-5xl: 4.25rem;
					--font-size-6xl: 5rem;

					--spacing-xs: 0.25rem;
					--spacing-sm: 0.5rem;
					--spacing-md: 1rem;
					--spacing-lg: 1.5rem;
					--spacing-xl: 2rem;
					--spacing-2xl: 3rem;
					--spacing-3xl: 4rem;
					--spacing-4xl: 6rem;
					--spacing-5xl: 8rem;

					--max-width: 720px;
					--wide-width: 1200px;
					--radius-sm: 6px;
					--radius: 10px;
					--radius-lg: 16px;
					--radius-full: 9999px;

					--transition-fast: 150ms ease;
					--transition-base: 200ms ease;
					--transition-slow: 300ms ease;

					--shadow-sm: 0 1px 2px rgba(0, 0, 0, 0.05);
					--shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -2px rgba(0, 0, 0, 0.1);
					--shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -4px rgba(0, 0, 0, 0.1);
					--shadow-xl: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 8px 10px -6px rgba(0, 0, 0, 0.1);
				}


				html { scroll-behavior: smooth; }

				body {
					font-family: var(--font-sans);
					font-size: var(--font-size-base);
					line-height: 1.6;
					color: var(--color-text);
					background: var(--color-bg);
					-webkit-font-smoothing: antialiased;
					min-height: 100vh;
				}

				a { color: currentColor; text-decoration: none; }
				img { max-width: 100%; height: auto; display: block; }

				h1, h2, h3, h4, h5, h6 { font-weight: 700; line-height: 1.2; letter-spacing: -0.02em; }
				h1 { font-size: var(--font-size-5xl); }
				h2 { font-size: var(--font-size-3xl); }
				h3 { font-size: var(--font-size-2xl); }
				h4 { font-size: var(--font-size-xl); }

				/* container + section rules now in site.css */

				.btn {
					display: inline-flex;
					align-items: center;
					justify-content: center;
					gap: var(--spacing-sm);
					padding: var(--spacing-sm) var(--spacing-lg);
					font-family: inherit;
					font-size: var(--font-size-sm);
					font-weight: 600;
					border-radius: var(--radius);
					cursor: pointer;
					transition: background var(--transition-fast), transform var(--transition-fast), box-shadow var(--transition-fast);
				}

				.btn:hover { transform: translateY(-1px); }
				.btn:active { transform: translateY(0); }

				.btn-primary {
					color: white;
					background: var(--color-primary);
					border: none;
				}

				.btn-primary:hover {
					background: var(--color-primary-dark);
					box-shadow: var(--shadow-lg);
				}

				.btn-secondary {
					color: var(--color-text);
					background: transparent;
					border: 1px solid var(--color-border);
				}

				.btn-secondary:hover {
					background: var(--color-surface);
					border-color: var(--color-muted);
				}

				.btn-lg {
					padding: var(--spacing-md) var(--spacing-xl);
					font-size: var(--font-size-base);
				}
			}
		</style>

		<style>
			.site-header {
				position: sticky;
				top: 0;
				z-index: 100;
				background: var(--color-bg);
				border-bottom: 1px solid var(--color-border);
			}

			.nav {
				max-width: var(--site-max-width);
				margin: 0 auto;
				padding: var(--space-md) var(--site-gutter);
				display: flex;
				align-items: center;
				gap: var(--space-lg);
			}

			.site-logo {
				font-size: var(--font-size-xl);
				font-weight: 800;
				letter-spacing: -0.03em;
				color: var(--color-primary);
			}

			.site-logo-img {
				height: 48px;
				width: auto;
				display: block;
				margin: -8px 0;
			}

			.nav-toggle {
				display: none;
				background: none;
				border: none;
				font-size: 24px;
				cursor: pointer;
				color: var(--color-text);
				margin-left: auto;
			}

			.nav-links {
				display: flex;
				gap: var(--spacing-lg);
				margin-left: auto;
			}

			.nav-links a {
				font-size: var(--font-size-sm);
				font-weight: 500;
				color: var(--color-muted);
				transition: color var(--transition-fast);
			}

			.nav-links a:hover { color: var(--color-text); }

			.nav-actions {
				display: flex;
				align-items: center;
				gap: var(--spacing-lg);
			}

			.nav-cta {
				padding: var(--spacing-sm) var(--spacing-md);
				font-size: var(--font-size-sm);
				font-weight: 600;
				color: white;
				background: var(--color-accent, #ff6b35);
				border-radius: var(--radius-sm);
				transition: background var(--transition-fast), transform var(--transition-fast);
			}

			.nav-cta:hover {
				background: #e55a2b;
				transform: translateY(-1px);
			}

			main { min-height: calc(100vh - 200px); }

			.site-footer {
				background: var(--color-dark-section, #1a2332);
				color: rgba(255, 255, 255, 0.85);
			}

			.footer-top {
				padding: var(--spacing-4xl) 0 var(--spacing-2xl);
			}

			.footer-grid {
				display: grid;
				grid-template-columns: 1.4fr 1fr 1fr 1.3fr;
				gap: var(--spacing-2xl);
			}

			.footer-brand {
				display: flex;
				flex-direction: column;
				gap: var(--spacing-md);
			}

			.footer-logo-img {
				height: 32px;
				width: auto;
				filter: brightness(0) invert(1);
			}

			.footer-tagline {
				font-size: var(--font-size-sm);
				color: rgba(255, 255, 255, 0.5);
				line-height: 1.6;
			}

			.footer-social {
				display: flex;
				gap: var(--spacing-sm);
				margin-top: var(--spacing-sm);
			}

			.footer-social a {
				width: 36px;
				height: 36px;
				display: flex;
				align-items: center;
				justify-content: center;
				border: 1px solid rgba(255, 255, 255, 0.15);
				border-radius: var(--radius-sm);
				color: rgba(255, 255, 255, 0.5);
				font-size: 18px;
				transition: all var(--transition-fast);
			}

			.footer-social a:hover {
				background: var(--color-primary);
				border-color: var(--color-primary);
				color: white;
			}

			.footer-col h4 {
				font-size: var(--font-size-sm);
				font-weight: 700;
				text-transform: uppercase;
				letter-spacing: 0.05em;
				color: white;
				margin-bottom: var(--spacing-lg);
			}

			.footer-col a,
			.footer-col p {
				display: flex;
				align-items: center;
				gap: var(--spacing-xs);
				font-size: var(--font-size-sm);
				color: rgba(255, 255, 255, 0.5);
				padding: var(--spacing-xs) 0;
				transition: color var(--transition-fast);
				text-decoration: none;
			}

			.footer-col a:hover { color: white; }

			.footer-col i {
				font-size: 16px;
				color: var(--color-primary);
				flex-shrink: 0;
			}

			.footer-contact p {
				line-height: 1.5;
			}

			.footer-hours {
				margin-top: var(--spacing-sm);
				font-size: var(--font-size-xs) !important;
			}

			.footer-bottom {
				border-top: 1px solid rgba(255, 255, 255, 0.1);
			}

			.footer-bottom-inner {
				padding: var(--spacing-lg) 0;
				display: flex;
				justify-content: space-between;
				align-items: center;
				flex-wrap: wrap;
				gap: var(--spacing-md);
				font-size: var(--font-size-xs);
				color: rgba(255, 255, 255, 0.35);
			}

			.footer-bottom-links {
				display: flex;
				gap: var(--spacing-lg);
			}

			.footer-bottom-links a {
				color: rgba(255, 255, 255, 0.35);
				text-decoration: none;
				transition: color var(--transition-fast);
			}

			.footer-bottom-links a:hover { color: rgba(255, 255, 255, 0.7); }

			.admin-link {
				display: flex;
				align-items: center;
				gap: 4px;
			}

			.footer-powered a { color: rgba(255, 255, 255, 0.5); }

			.phronema-link {
				font-weight: 600;
				color: #FF6B35 !important;
				transition: opacity var(--transition-fast);
			}

			.phronema-link:hover { opacity: 0.8; }

			@media (max-width: 768px) {
				.nav-toggle { display: block; }

				.nav-links {
					display: none;
					position: absolute;
					top: 100%;
					left: 0;
					right: 0;
					background: var(--color-bg);
					border-bottom: 1px solid var(--color-border);
					flex-direction: column;
					padding: var(--spacing-md) var(--spacing-lg);
					gap: var(--spacing-sm);
				}

				.nav-links.nav-open { display: flex; }
				.nav-actions .nav-cta { display: none; }

				.footer-grid { grid-template-columns: 1fr 1fr; gap: var(--spacing-xl); }
				.footer-bottom-inner { flex-direction: column; text-align: center; }
				.footer-bottom-links { flex-wrap: wrap; justify-content: center; }

				h1 { font-size: var(--font-size-4xl); }
				h2 { font-size: var(--font-size-2xl); }
			}

			@media (max-width: 480px) {
				.footer-grid { grid-template-columns: 1fr; }
			}
		</style>
	</body>
</html>
