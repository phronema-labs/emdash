---
import { getEmDashCollection } from "emdash";
import Base from "../../layouts/Base.astro";
import PostCard from "../../components/PostCard.astro";
import PageHero from "../../components/PageHero.astro";

const { entries: posts, cacheHint } = await getEmDashCollection("posts", { status: "published" });
if (cacheHint) Astro.response.headers.set("Cache-Control", cacheHint);

const sortedPosts = posts.sort((a, b) => {
	const dateA = a.data.publishedAt ? new Date(a.data.publishedAt).getTime() : 0;
	const dateB = b.data.publishedAt ? new Date(b.data.publishedAt).getTime() : 0;
	return dateB - dateA;
});
---

<Base title="Blog" description="Tips, maintenance advice, and energy-saving guides for homeowners.">
	<PageHero
		title="Blog"
		subtitle="Tips, maintenance advice, and energy-saving guides for homeowners."
		image="https://images.unsplash.com/photo-1486312338219-ce68d2c6f44d?w=1600&h=500&fit=crop"
	/>

	<section class="container section">

		{sortedPosts.length > 0 ? (
			<div class="posts-grid">
				{sortedPosts.map((post) => (
					<PostCard
						title={post.data.title}
						excerpt={post.data.excerpt}
						featuredImage={post.data.featured_image}
						href={`/blog/${post.slug}`}
						date={post.data.publishedAt}
					/>
				))}
			</div>
		) : (
			<p style="text-align: center; color: var(--color-muted);">
				No posts yet. <a href="/_emdash/admin">Write your first post</a>.
			</p>
		)}
	</section>
</Base>

<style>
	.posts-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: var(--spacing-xl);
	}

	@media (max-width: 900px) {
		.posts-grid { grid-template-columns: repeat(2, 1fr); }
	}

	@media (max-width: 600px) {
		.posts-grid { grid-template-columns: 1fr; }
	}
</style>
